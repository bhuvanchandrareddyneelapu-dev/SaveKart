{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "java -jar app.jar",
    "healthcheckPath": "/api/v1/categories",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE"
  }
}
